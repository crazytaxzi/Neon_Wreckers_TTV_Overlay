# Public deployment identity
PUBLIC_HOST=game.example.com
ACME_EMAIL=admin@example.com
PUBLIC_WEB_URL=https://game.example.com
CORS_ORIGINS=https://game.example.com

# Runtime
NODE_ENV=production
TRUST_PROXY=true
COOKIE_SECURE=true
LOG_LEVEL=info
RATE_LIMIT_MAX=1200
RATE_LIMIT_WINDOW_SECONDS=60

# PostgreSQL
POSTGRES_USER=neon
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=neon_wreckers
DATABASE_URL=postgresql://neon:replace-with-a-long-random-password@postgres:5432/neon_wreckers?schema=public

# Redis
REDIS_PASSWORD=replace-with-a-different-long-random-password
REDIS_URL=redis://:replace-with-a-different-long-random-password@redis:6379

# Sessions
SESSION_COOKIE_NAME=nw_session
SESSION_SECRET=replace-with-at-least-32-random-bytes

# Twitch OAuth
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=https://game.example.com/api/v1/auth/twitch/callback
TWITCH_REQUIRED_SCOPES=user:read:email user:read:chat moderator:read:followers channel:read:subscriptions bits:read
TWITCH_EVENTSUB_SECRET=replace-with-a-random-secret-at-least-32-characters
CREDENTIAL_ENCRYPTION_KEY=replace-with-a-distinct-random-secret-at-least-32-characters
STREAMER_TWITCH_ID=

# StreamElements loyalty integration
STREAMELEMENTS_PROVIDER=disabled
STREAMELEMENTS_CHANNEL_ID=
STREAMELEMENTS_JWT=
STREAMELEMENTS_API_BASE=https://api.streamelements.com/kappa/v2
FEATURE_POINTS_ACTIONS=false

# Operations
BACKUP_RETENTION_DAYS=14
IMAGE_TAG=2.0.0
