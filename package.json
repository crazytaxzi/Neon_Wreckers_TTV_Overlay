{
  "name": "neon-wreckers-station-zero",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.0",
  "engines": {
    "node": ">=22.16.0",
    "pnpm": ">=10.32.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "clean": "node tools/clean.mjs",
    "dev": "pnpm --recursive --if-present run dev",
    "build": "pnpm run clean && pnpm --filter @neon-wreckers/integrations run build && pnpm --filter @neon-wreckers/ui run build && pnpm run db:generate && tsc -p infrastructure/database/tsconfig.json && pnpm --filter @neon-wreckers/api run build && pnpm --filter @neon-wreckers/worker run build && pnpm --filter @neon-wreckers/web run build && pnpm --filter @neon-wreckers/admin run build && pnpm --filter @neon-wreckers/overlay run build",
    "test": "pnpm run clean && pnpm run test:engine && pnpm run test:api && pnpm run test:content && pnpm run test:dependencies && pnpm run test:repository",
    "test:engine": "node --test packages/game-engine/test/*.test.mjs",
    "test:content": "node tools/validate-content.mjs",
    "test:repository": "node --test tools/test/*.test.mjs",
    "test:browser": "playwright test",
    "test:browser:update": "playwright test --update-snapshots",
    "verify": "pnpm run test && pnpm run build",
    "db:generate": "prisma generate --schema infrastructure/database/prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema infrastructure/database/prisma/schema.prisma",
    "db:seed": "tsx infrastructure/database/seed/seed.ts",
    "db:seed:production": "node infrastructure/database/dist/seed/seed.js",
    "test:api": "tsx --test tools/test/*.test.ts",
    "test:dependencies": "node tools/audit-dependencies.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.2",
    "@playwright/test": "1.55.0",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "tsx": "4.23.0",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@neon-wreckers/content": "workspace:*",
    "@neon-wreckers/game-engine": "workspace:*",
    "@prisma/client": "6.19.3",
    "prisma": "6.19.3"
  }
}
