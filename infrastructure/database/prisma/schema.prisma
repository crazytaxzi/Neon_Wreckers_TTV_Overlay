generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  player
  streamer
  admin
}

enum Career {
  salvager
  hauler
  engineer
  builder
  explorer
  trader
}

enum ModuleState {
  locked
  building
  active
  damaged
  disabled
  upgrading
  seasonal
}

enum WreckRisk {
  low
  moderate
  high
  extreme
}

enum ExpeditionStatus {
  available
  active
  resolved
  claimed
  failed
}

enum TxStatus {
  pending
  committed
  refunded
  ambiguous
  failed
}

enum ContentLifecycle {
  draft
  scheduled
  active
  retired
  archived
}

model User {
  id              String               @id @default(cuid())
  twitchUserId    String               @unique
  twitchLogin     String
  displayName     String
  avatarUrl       String?
  email           String?
  roles           Role[]               @default([player])
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  player          Player?
  sessions        Session[]
  loyaltyTx       LoyaltyTransaction[]
  auditLogs       AuditLog[]
  contentVersions ContentVersion[]
  twitchCredential TwitchCredential?
}

model TwitchCredential {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessTokenEncrypted String
  refreshTokenEncrypted String
  scopes               String[] @default([])
  expiresAt            DateTime
  updatedAt            DateTime @updatedAt
}

model Player {
  id                String           @id @default(cuid())
  userId            String           @unique
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  credits           Int              @default(1240)
  xp                Int              @default(0)
  level             Int              @default(1)
  reputation        Int              @default(0)
  career            Career           @default(salvager)
  title             String           @default("Cutter Pilot")
  careerChosenAt    DateTime?
  careerChangedAt   DateTime?
  inventoryCapacity Int              @default(80)
  bannedUntil       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  inventory         InventoryStack[]
  ships             Ship[]
  crew              CrewMember[]
  expeditions       Expedition[]
  history           HistoryEntry[]
  notifications     Notification[]
  quarters          QuartersLayout?
  exhibits          MuseumExhibit[]
  marketTransactions MarketTransaction[]
  cooldowns         ActionCooldown[]
  auctionSales      AuctionListing[] @relation("AuctionSeller")
  auctionPurchases  AuctionListing[] @relation("AuctionBuyer")
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
}

model Station {
  id              String            @id @default(cuid())
  slug            String            @unique
  name            String
  level           Int               @default(1)
  population      Int               @default(0)
  power           Int               @default(100)
  morale          Int               @default(60)
  integrity       Int               @default(100)
  storageCapacity Int               @default(1000)
  storageUsed     Int               @default(0)
  threatLevel     Int               @default(1)
  activeSeason    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  resources       StationResource[]
  modules         StationModule[]
  wrecks          Wreck[]
  history         HistoryEntry[]
  alerts          StationAlert[]
}

model StationResource {
  id        String  @id @default(cuid())
  stationId String
  station   Station @relation(fields: [stationId], references: [id], onDelete: Cascade)
  slug      String
  amount    Int     @default(0)

  @@unique([stationId, slug])
}

model StationModule {
  id        String      @id @default(cuid())
  stationId String
  station   Station     @relation(fields: [stationId], references: [id], onDelete: Cascade)
  slug      String
  name      String
  level     Int         @default(0)
  state     ModuleState @default(locked)
  progress  Int         @default(0)
  integrity Int         @default(100)
  visualKey String
  effects   Json        @default("{}")
  plaques   Plaque[]
  projects  ConstructionProject[]
  updatedAt DateTime    @updatedAt

  @@unique([stationId, slug])
}

model Plaque {
  id         String        @id @default(cuid())
  moduleId   String
  module     StationModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title      String
  body       String
  playerName String?
  createdAt  DateTime      @default(now())

  @@index([moduleId, createdAt])
}

model StationAlert {
  id        String    @id @default(cuid())
  stationId String
  station   Station   @relation(fields: [stationId], references: [id], onDelete: Cascade)
  severity  String
  title     String
  body      String
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@index([stationId, createdAt])
}

model Wreck {
  id                  String    @id @default(cuid())
  stationId           String
  station             Station   @relation(fields: [stationId], references: [id], onDelete: Cascade)
  archetype           String
  name                String
  description         String
  risk                WreckRisk
  integrity           Int
  depleted            Boolean   @default(false)
  visualKey           String
  remainingLootBudget Int
  discoveredBy        String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([stationId, depleted, createdAt])
}

model InventoryStack {
  id        String   @id @default(cuid())
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  itemSlug  String
  name      String
  quantity  Int
  rarity    String
  visualKey String
  updatedAt DateTime @updatedAt

  @@unique([playerId, itemSlug])
}

model Ship {
  id            String   @id @default(cuid())
  playerId      String
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  name          String
  classSlug     String
  condition     Int      @default(100)
  fuel          Int      @default(4)
  cargoCapacity Int      @default(24)
  upgrades      String[] @default([])
  visualKey     String
  createdAt     DateTime @default(now())
  expeditions   Expedition[]

  @@index([playerId, createdAt])
}

model CrewMember {
  id           String    @id @default(cuid())
  playerId     String
  player       Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  name         String
  role         String
  level        Int       @default(1)
  morale       Int       @default(75)
  injuredUntil DateTime?
  traits       String[]  @default([])

  @@index([playerId])
}

model Expedition {
  id          String           @id @default(cuid())
  playerId    String
  player      Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)
  definition  String
  shipId      String?
  ship        Ship?            @relation(fields: [shipId], references: [id], onDelete: SetNull)
  crewIds     String[]          @default([])
  name        String
  status      ExpeditionStatus
  risk        WreckRisk
  launchedAt  DateTime?
  resolvesAt  DateTime?
  rewards     Json             @default("[]")
  incidentLog Json             @default("[]")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([playerId, createdAt])
  @@index([status, resolvesAt])
  @@index([shipId, status])
}

model ConstructionProject {
  id           String        @id @default(cuid())
  moduleId     String
  module       StationModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  targetLevel  Int
  kind         String
  status       String        @default("active")
  requirements Json
  contributed  Json          @default("{}")
  createdAt    DateTime      @default(now())
  completedAt  DateTime?

  @@index([moduleId, status])
}

model ActionCooldown {
  id        String   @id @default(cuid())
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  actionKey String
  expiresAt DateTime
  updatedAt DateTime @updatedAt

  @@unique([playerId, actionKey])
  @@index([expiresAt])
}

model ActionReceipt {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  playerId       String?
  action         String
  responseJson   Json     @default("{}")
  createdAt      DateTime @default(now())

  @@index([playerId, createdAt])
}

model MarketTransaction {
  id          String   @id @default(cuid())
  playerId    String
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  direction   String
  itemSlug    String
  quantity    Int
  credits     Int
  createdAt   DateTime @default(now())

  @@index([playerId, createdAt])
}

model AuctionListing {
  id           String   @id @default(cuid())
  sellerId     String
  seller       Player   @relation("AuctionSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  buyerId      String?
  buyer        Player?  @relation("AuctionBuyer", fields: [buyerId], references: [id], onDelete: SetNull)
  itemSlug     String
  itemName     String
  quantity     Int
  priceCredits Int
  status       String   @default("active")
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  soldAt       DateTime?

  @@index([status, expiresAt, createdAt])
  @@index([sellerId, status])
}

model QuartersLayout {
  id        String   @id @default(cuid())
  playerId  String   @unique
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  theme     String
  objects   Json     @default("[]")
  updatedAt DateTime @updatedAt
}

model MuseumExhibit {
  id          String   @id @default(cuid())
  playerId    String
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  itemSlug    String
  name        String
  donatedAt   DateTime @default(now())

  @@unique([playerId, itemSlug])
  @@index([donatedAt])
}

model ExternalEvent {
  id          String   @id @default(cuid())
  provider    String
  externalId  String
  type        String
  actorId     String?
  payload     Json
  processedAt DateTime?
  createdAt   DateTime @default(now())

  @@unique([provider, externalId])
  @@index([type, createdAt])
}

model RuntimeEvent {
  id          String   @id @default(cuid())
  slug        String
  status      String
  source      String
  payload     Json     @default("{}")
  startsAt    DateTime
  endsAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([slug, status])
  @@index([startsAt, endsAt])
}

model HistoryEntry {
  id               String   @id @default(cuid())
  stationId        String
  station          Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)
  playerId         String?
  player           Player?  @relation(fields: [playerId], references: [id], onDelete: SetNull)
  category         String
  title            String
  body             String
  actorDisplayName String?
  createdAt        DateTime @default(now())

  @@index([stationId, createdAt])
  @@index([playerId, createdAt])
}

model Notification {
  id        String    @id @default(cuid())
  playerId  String
  player    Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  type      String
  priority  Int       @default(0)
  title     String
  body      String
  deepLink  String?
  readAt    DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@index([playerId, createdAt])
}

model LoyaltyTransaction {
  id                String   @id @default(cuid())
  provider          String
  idempotencyKey    String   @unique
  playerId          String
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  broadcasterId     String
  amount            Int
  actionSlug        String
  status            TxStatus
  externalReference String?
  requestJson       Json     @default("{}")
  responseJson      Json     @default("{}")
  error             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model ContentVersion {
  id          String           @id @default(cuid())
  version     Int
  slug        String
  lifecycle   ContentLifecycle
  contentJson Json
  validation  Json             @default("{}")
  publishedAt DateTime?
  scheduledAt DateTime?
  expiresAt   DateTime?
  createdById String?
  createdBy   User?            @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())

  @@unique([slug, version])
  @@index([lifecycle, scheduledAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  target    String
  before    Json?
  after     Json?
  ip        String?
  requestId String?
  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([target, createdAt])
}
